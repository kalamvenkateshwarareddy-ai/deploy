# ── Bedrock ──────────────────────────────────────────────
BEDROCK_REGION=us-east-1
BEDROCK_MODEL=amazon.titan-embed-text-v2:0

# ── OpenSearch ───────────────────────────────────────────
# Paste your OpenSearch domain endpoint here (without https://)
# Example: search-my-domain-abc123.us-east-1.es.amazonaws.com
OPENSEARCH_HOST=search-rag-vectors-sxwkuhhmizkzdicgpjsejcfbyi.us-east-1.es.amazonaws.com
OPENSEARCH_REGION=us-east-1
OPENSEARCH_INDEX=rag_chunks

# ── Chunking ─────────────────────────────────────────────
CHUNK_SIZE=900
OVERLAP=150
K=4

PORT=5000
